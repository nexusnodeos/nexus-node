# Copia este archivo como .env.local y reemplaza con tus credenciales de Supabase.
# Reinicia `npm run dev` después de guardar los cambios.

NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui

# Requerida solo en servidor para /api/contratos (generación de PDF).
# NUNCA agregar el prefijo NEXT_PUBLIC_ a esta — no debe llegar al navegador.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui
